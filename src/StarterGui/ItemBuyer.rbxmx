				<Item class="LocalScript" referent="RBXB08D1DBE19A042F4B58B51832DC232B8">
					<Properties>
						<ProtectedString name="Source"><![CDATA[-- Calm ambient drift: slow ease in/out, no visible reset, no seam.
local TweenService = game:GetService("TweenService")
local image = script.Parent

-- tiny drift range so it never scrolls off or shows an edge
local DRIFT = 0.06           -- 6% of width, very subtle
local DURATION = 18          -- slow

image.Position = UDim2.new(-DRIFT/2, 0, 0, 0)

local info = TweenInfo.new(
	DURATION,
	Enum.EasingStyle.Sine,           -- smooth, no harsh start/stop
	Enum.EasingDirection.InOut,
	-1,                              -- repeat forever
	true                            -- reverses, so it breathes back and forth
)

TweenService:Create(image, info, {
	Position = UDim2.new(DRIFT/2, 0, 0, 0)
}):Play()]]></ProtectedString>
						<bool name="Disabled">false</bool>
						<Content name="LinkedSource"><null></null></Content>
